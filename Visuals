local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Freeze Trade",
   LoadingTitle = "Baddies Hub",
   LoadingSubtitle = "by Yoshida",
   ConfigurationSaving = {
      Enabled = false
   }
})

local player = game.Players.LocalPlayer

-- CHECK HOLD FUNCTION
local function checkHold(item)
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")

        if tool and tool.Name == item then
            Rayfield:Notify({
                Title = "Dupe System",
                Content = "Successful Dupe!",
                Duration = 3
            })
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "You must hold "..item.."!",
                Duration = 3
            })
        end
    end
end

