local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Dupe Weapons • Baddies ",
   LoadingTitle = "Tora Hub",
   LoadingSubtitle = "by Tora",
   ConfigurationSaving = {
      Enabled = false
   }
})

local player = game.Players.LocalPlayer


local function checkHold(item)
    local char = player.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")

        if tool and tool.Name == item then
            Rayfield:Notify({
                Title = "Dupe System",
                Content = "Successful Dupe!",
                Duration = 3
            })
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "You must hold "..item.."!",
                Duration = 3
            })
        end
    end
end

local MainTab = Window:CreateTab("Main", 4483362458)
local DupeTab = Window:CreateTab("Dupe", 4483362458)
local TradeTab = Window:CreateTab("Freeze Trade", 4483362458)
local SettingsTab = Window:CreateTab("Settings", 4483362458)
